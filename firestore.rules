rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin check ────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == true)
        ||
        (exists(/databases/$(database)/documents/vendors/$(request.auth.uid))
          && get(/databases/$(database)/documents/vendors/$(request.auth.uid)).data.is_admin == true)
      );
    }

    // ── Admin-only fields that clients may never update ────────
    function noAdminFieldsChanged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny([
          'is_approved', 'is_active', 'verification_status',
          'avg_rating', 'total_events', 'total_revenue', 'total_reviews',
          'response_rate', 'cancellation_rate', 'repeat_client_rate'
        ]);
    }

    // ── Vendors collection ─────────────────────────────────────
    match /vendors/{uid} {

      // PUBLIC: anyone (including unauthenticated clients) can browse vendor profiles
      allow read: if true;

      // Vendor can create their own doc with safe defaults only
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.is_approved == false
        && request.resource.data.is_active == false
        && request.resource.data.verification_status == 'pending';

      // Vendor can update their own doc but cannot touch admin-only fields
      allow update: if request.auth != null
        && request.auth.uid == uid
        && noAdminFieldsChanged();

      // Deletes always via admin SDK only
      allow delete: if false;

      // ── packages sub-collection ────────────────────────────
      // PUBLIC read so clients can see packages on supplier profile
      match /packages/{packageId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // ── products sub-collection ────────────────────────────
      // PUBLIC read so clients can see products on supplier profile
      match /products/{productId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // ── media sub-collection ───────────────────────────────
      match /media/{mediaId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── availability sub-collection ────────────────────────
      match /availability/{availId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── pricing_rules sub-collection ───────────────────────
      match /pricing_rules/{ruleId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── documents sub-collection ───────────────────────────
      match /documents/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // ── reviews sub-collection ─────────────────────────────
      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Users collection ───────────────────────────────────────
    match /users/{uid} {
      // Any authenticated user can read (needed for vendor to fetch client photo)
      allow read: if request.auth != null;
      // Only the user themselves can write their own doc
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Events collection ──────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.user_id == request.auth.uid);
      allow write: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null;
    }

    // ── Leads collection ───────────────────────────────────────
    match /leads/{leadId} {
      // Both client and vendor can read their own leads; admin can read all
      allow read: if isAdmin() || (request.auth != null
        && (resource.data.vendor_id == request.auth.uid
            || resource.data.client_id == request.auth.uid));

      // Authenticated clients can create leads
      allow create: if request.auth != null;

      // Vendor can update status; client can update last_message fields
      allow update: if request.auth != null
        && (resource.data.vendor_id == request.auth.uid
            || resource.data.client_id == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updated_at', 'last_message', 'last_message_at']);

      allow delete: if false;

      // ── messages sub-collection ────────────────────────────
      match /messages/{msgId} {
        allow read, create: if request.auth != null
          && (get(/databases/$(database)/documents/leads/$(leadId)).data.vendor_id == request.auth.uid
              || get(/databases/$(database)/documents/leads/$(leadId)).data.client_id == request.auth.uid);
        allow update, delete: if false;
      }
    }

    // ── Orders collection ──────────────────────────────────────
    // Clients (authenticated or not) can place orders
    match /orders/{orderId} {
      allow create: if true;
      allow read: if request.auth != null
        && resource.data.client_uid == request.auth.uid;
      allow update, delete: if false;
    }

    // All other paths denied
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
